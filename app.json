{
  "expo": {
    "name": "JobToo",
    "slug": "jobtoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/jt-logo.jpg",
    "scheme": "onspaceapp",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "55.0.0",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "merchantIdentifier": "merchant.com.nikidav23.onspaceapp",
      "bundleIdentifier": "com.nikidav23.onspaceapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/jt-logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nikidav23.onspaceapp",
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/jt-logo.jpg",
      "name": "JobToo",
      "shortName": "JobToo",
      "themeColor": "#FF6B1A",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jt-logo.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b26bb1e-9e73-4d94-8907-b27e3f66096f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5b26bb1e-9e73-4d94-8907-b27e3f66096f",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "owner": "nikidav23"
  }
}